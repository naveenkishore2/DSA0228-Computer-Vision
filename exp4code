#exp-4 Image Scaling (Bigger and Smalle)
import cv2
from google.colab.patches import cv2_imshow # Import cv2_imshow

img = cv2.imread("flower_image.png")

# Check if image was loaded successfully
if img is None:
    print("Error: Could not load image. Please check the file path.")
else:
    bigger = cv2.resize(img, None, fx=2, fy=2)
    smaller = cv2.resize(img, None, fx=0.5, fy=0.5)

    cv2_imshow(img)
    cv2_imshow(bigger)
    cv2_imshow(smaller)

# cv2.waitKey(0) and cv2.destroyAllWindows() are not needed with cv2_imshow
# and can cause issues if not run in a proper GUI environment.
